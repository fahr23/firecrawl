@article{preskill2018,
  title = {Quantum Computing in the NISQ era and beyond},
  author = {Preskill, John},
  journal = {QUANTUM},
  year = {2018},
  doi = {10.22331/q-2018-08-06-79},
  url = {https://www.webofscience.com/api/gateway?GWVersion=2&SrcApp=ffftest&SrcAuth=WosAPI&KeyUT=WOS:000457936400001&DestLinkType=FullRecord&DestApp=WOS_CPL},
  abstract = {Noisy Intermediate-Scale Quantum (NISQ) technology will be available in the near future. Quantum computers with 50-100 qubits may be able to perform tasks which surpass the capabilities of today's classical digital computers, but noise in quantum gates will limit the size of quantum circuits that can be executed reliably. NISQ devices will be useful tools for exploring many-body quantum physics, and may have other useful applications, but the 100-qubit quantum computer will not change the world },
}

